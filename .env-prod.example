# Environment
ENVIRONMENT=prod
DB_TYPE=postgres
API_NAME=FrozenVault Backend

# FastAPI is served by nginx under /frozen-vault in docker-compose-prod.yml.
API_ROOT_PATH=/frozen-vault

# Supabase PostgreSQL connection
DB_USER=postgres
DB_PASSWORD=replace-with-supabase-password
DB_NAME=postgres
DB_HOST=replace-with-supabase-host
DB_PORT=5432
DB_SSLMODE=require
