# Environment
ENVIRONMENT=prod
DB_TYPE=postgres
API_NAME=Fridge Inventory App Backend

# FastAPI is served by nginx under /backend in docker-compose-prod.yml.
API_ROOT_PATH=/backend

# Supabase PostgreSQL connection
DB_USER=postgres
DB_PASSWORD=replace-with-supabase-password
DB_NAME=postgres
DB_HOST=replace-with-supabase-host
DB_PORT=5432
DB_SSLMODE=require
